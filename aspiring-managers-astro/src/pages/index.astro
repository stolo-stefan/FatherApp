---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Aspiring Managers - Astro test">
  <section class="max-w-2xl mx-auto px-4 py-12">
    <h1 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">
      Astro + Tailwind este configurat ✅
    </h1>
    <p class="text-slate-600 mb-4">
      Aceasta este pagina de test. Mai jos vom adăuga paginile de blog.
    </p>
    <a
      href="/blog/test-slug"
      class="inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-medium shadow-sm hover:shadow-md hover:-translate-y-0.5 transition"
    >
      Mergi la o pagină de blog de test
      <span aria-hidden="true">→</span>
    </a>
  </section>
</Layout>
