{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },           
    { "source": "/assets/(.*)", "destination": "/assets/$1" },    
    { "source": "/(.*\\.(?:js|css|svg|png|jpg|jpeg|gif|ico|json|txt|woff2?))", "destination": "/$1" }, 
    { "source": "/(.*)", "destination": "/index.html" }           
  ]
}
