###########################
# .NET / C# build outputs #
###########################
bin/
obj/
*.user
*.suo
*.userosscache
*.sln.docstates

# Compiled binaries and runtime outputs
*.dll
*.exe
*.pdb
*.cache
*.log
*.dbmdl
*.dbproj.schemaview

# Publish directories
publish/
out/
dist/

###########################
# Entity Framework / Tools #
###########################
# EF migration design-time files
*.ide/
*.vscode/
# Keep migrations committed for schema tracking (comment out next line if not)
# !backend/Migrations/

###########################
# Configuration / Secrets  #
###########################
# Do NOT commit local settings or secrets
appsettings.Development.json
appsettings.Local.json
appsettings.*.local.json
secrets.json

# Environment variable files
.env
.env.*
!.env.example        # Keep a sample env file for teammates

# User Secrets (for local dev)
**/secrets.json
**/Properties/launchSettings.json

###########################
# Docker / Containers      #
###########################
# Ignore local Docker volumes, cache, and data
**/azurite_data/
**/.azurite
**/mysql_data/
**/dp_keys/
**/DataProtection-Keys/
**/logs/

# Docker Compose override files (optional)
docker-compose.override.yml

# Build cache and intermediate layers
**/.docker
**/.dockerignore
.dockerignore

###########################
# Logs / Temp / Caches     #
###########################
*.log
logs/
temp/
tmp/
*.tmp
*.bak
*.swp
*.DS_Store
Thumbs.db

###########################
# Uploaded media (local)   #
###########################
# Azure-hosted blobs are remote — only local dev uploads need ignoring
wwwroot/uploads/
wwwroot/media/
wwwroot/files/
wwwroot/blogs/
wwwroot/storage/

# ignore all local Azurite files
__azurite_db*__.json
__blobstorage__/
__queuestorage__/

###########################
# IDE / Editor folders     #
###########################
.vscode/
.idea/
*.ncrunchsolution
*.ncrunchproject
_ReSharper.*
*.DotSettings.user
*.vs/
.vsconfig

###########################
# OS files                 #
###########################
.DS_Store
Thumbs.db
desktop.ini

###########################
# Node / Frontend (if in same repo)
###########################
node_modules/
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
.vite/
dist/
coverage/

# Frontend environment files
.env.local
.env.development
.env.production

###########################
# Miscellaneous            #
###########################
# Backup or temporary files
*.orig
*.rej
*.bak
*.tmp
*.swp

# JetBrains Rider / VS temporary metadata
.idea/
*.iml
